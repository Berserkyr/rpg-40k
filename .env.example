# Configuration backend
# Laisser vide pour utiliser le MJ local sans OpenAI.
OPENAI_API_KEY=

# Configuration frontend au build Docker.
# En production avec le reverse proxy fourni, garder /api.
VITE_API_BASE=/api

# Déploiement VPS
DOMAIN=example.com
APP_DIR=/opt/rpg-40k

# Port local du conteneur frontend sur le VPS.
# 127.0.0.1:8081 évite d'écraser un site déjà en production sur 80/443.
RPG40K_BIND_ADDRESS=127.0.0.1
RPG40K_HTTP_PORT=8081
